# Docker Compose deployment variables for ECHO

# Database
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=echo
MYSQL_USER=echo_admin
MYSQL_PASSWORD=change_this_app_password

# Backend
BACKEND_PORT=8084
ECHO_JWT_SECRET=replace_with_a_random_string_of_32_or_more_characters
## //CAMBIAR A DOMINIO REAL
CORS_ALLOWED_ORIGIN=http://localhost:8083
# Upload storage path inside backend container (keep default unless needed)
APP_UPLOAD_DIR=/app/uploads
# Public base URL used to build file URLs returned by the API (must match the browser-accessible URL)
# APP_BASE_URL=http://localhost:8083

# Frontend
FRONTEND_PORT=8083
VITE_API_URL=/api
## //CAMBIAR A DOMINIO REAL
TRAEFIK_HOST=ip del host

# Optional admin bootstrap (used by admin-init profile)
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_USERNAME=admin

# Prefer hash in production. Example format: $2a$10$...
APP_ADMIN_PASSWORD_HASH=

# Only for local/dev convenience. Leave empty in production.
APP_ADMIN_PASSWORD=