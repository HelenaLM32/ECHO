# Development Environment Configuration

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/echo
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Secret (must be at least 32 characters for security)
# Use a strong random string in production
ECHO_JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_32_chars

# Production SSL Configuration (only needed for prod profile)
# SSL_KEYSTORE_PATH=/path/to/keystore.jks
# SSL_KEYSTORE_PASSWORD=your_keystore_password